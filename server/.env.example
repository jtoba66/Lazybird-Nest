# Server Environment
PORT=3001
NODE_ENV=development

# JWT
JWT_SECRET=your-secret-key-change-in-production

# Jackal
JACKAL_SEED=your-mnemonic-phrase-here
JACKAL_RPC_URL=https://rpc.jackalprotocol.com
JACKAL_API_URL=https://api.jackalprotocol.com

# Stripe
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Email (Optional - Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=Nest <noreply@nest.app>

# Frontend URL
FRONTEND_URL=http://localhost:5173

# Download Gateway
DOWNLOAD_GATEWAY_URL=https://gateway.lazybird.io

# Firebase / FCM (Optional)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# Alternative to the three vars above:
# FIREBASE_SERVICE_ACCOUNT_JSON={"project_id":"...","client_email":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"}
